#!/usr/bin/env bash

set -eu

verbose=false
while getopts ':v' opt; do
    case $opt in
        v) verbose=true ;;
    esac
done
shift $((OPTIND - 1))

attrs=(normal bright dim italic underscore blink rapid_blink reverse hidden strike)
colors=(black red green yellow blue magenta cyan white)

normal=$'\e[0m'
dim=$'\e[2m'
fg_offset=30
bg_offset=40

echo "current \$TERM: ${TERM:-<unset>}"

echo
echo "  Usage: \\e[*;**(;**)m"
echo "Default: \\e[0m"
echo

for ((attr = 0; attr < ${#attrs[@]}; attr++)); do
    name="${attrs[attr]//_/ }"
    spec="${attr};**;**"
    ctrl=$'\e['"${attr}m"
    printf '%-11s <%s%s%s>\n' "$name" "$ctrl" "$spec" "$normal"
done

echo

# Foreground header row
printf '%10s' ''
for c in "${colors[@]}"; do
    printf '  %7s ' "$c"
done
echo

for ((bg = 0; bg < ${#colors[@]}; bg++)); do
    bgn=$((bg + bg_offset))
    echo

    for attr in 0 1; do
        # Background header col
        if ((attr == 0)); then
            printf '%-10s' "on_${colors[bg]}"
        else
            printf '%-10s' ''
        fi

        for ((fg = 0; fg < ${#colors[@]}; fg++)); do
            fgn=$((fg + fg_offset))
            spec="${attr};${fgn};${bgn}"
            ctrl=$'\e['"${spec}m"
            printf ' %s %s %s' "$ctrl" "$spec" "$normal"
        done

        echo
    done
done

echo

# first the system ones:
echo "256 colors: fg \\e[38;5;**m, bg \\e[48;5;**m"
echo

echo "System colors: 0-7, 8-15"

# regular
for i in {0..7}; do
    if $verbose; then
        fg=$((i == 0 || i == 4 ? 15 : 0))
        printf '\e[48;5;%dm\e[38;5;%dm %2d ' "$i" "$fg" "$i"
    else
        printf '\e[48;5;%dm  ' "$i"
    fi
done
echo "$normal"

# bright
for i in {8..15}; do
    if $verbose; then
        fg=$((i == 8 || i == 12 ? 15 : 0))
        printf '\e[48;5;%dm\e[38;5;%dm %2d ' "$i" "$fg" "$i"
    else
        printf '\e[48;5;%dm  ' "$i"
    fi
done
echo "$normal"
echo

# now the color cube
echo "Color cube, 6x6x6: 16-231"

for row in {1..6}; do
    for block in {1..6}; do
        for cell in {1..6}; do
            red=$((row - 1))
            green=$((block - 1))
            blue=$((cell - 1))
            color=$((16 + (red * 6 + green) * 6 + blue))

            if ((cell == 1)); then
                if ((block == 1)); then
                    printf '%s%3d%s' "$dim" "$color" "$normal"
                fi
                printf ' '
            fi

            if $verbose; then
                fg=$((row + block < 6 ? 15 : 0))
                printf '\e[48;5;%dm\e[38;5;%dm %3d ' "$color" "$fg" "$color"
            else
                printf '\e[48;5;%dm  ' "$color"
            fi
        done

        printf '%s' "$normal"
    done

    echo
done

echo

# now the grayscale ramp
echo "Grayscale ramp: 232-255"

for i in {232..255}; do
    if $verbose; then
        fg=$((i < 244 ? 15 : 0))
        printf '\e[48;5;%dm\e[38;5;%dm %3d ' "$i" "$fg" "$i"
    else
        printf '\e[48;5;%dm  ' "$i"
    fi
done
echo "$normal"
echo

# true colors (adapted from https://gist.github.com/XVilka/8346728)
echo "True colors: fg \\e[38;2;RRR;GGG;BBBm, bg \\e[48;2;RRR;GGG;BBBm"
columns=${COLUMNS:-90}

for complement in 0 1; do
    for ((col = 0; col < columns; col++)); do
        r=$((255 - (col * 255 / columns)))
        g=$((col * 510 / columns))
        b=$((col * 255 / columns))
        if ((g > 255)); then
            g=$((510 - g))
        fi

        if ((complement)); then
            r=$((255 - r))
            g=$((255 - g))
            b=$((255 - b))
        fi

        printf '\e[48;2;%d;%d;%dm ' "$r" "$g" "$b"
    done

    echo "$normal"
done
