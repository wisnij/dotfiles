#!/bin/bash
# Squash merge a feature branch onto master

set -eu

mode=squash
while getopts "ms" opt; do
    case $opt in
        m) mode=merge ;;
        s) mode=squash ;;
    esac
done
shift $((OPTIND - 1))

branch=''
if [[ $# -gt 0 ]]; then
    branch=$1
    shift
fi

master='master'
if git show-ref --verify --quiet refs/heads/main; then
    master='main'
fi

if [[ -z $branch ]]; then
    branch=$(git branch --show-current)
fi

if [[ $branch == $master ]]; then
    echo "Already on '$branch'" >&2
    exit 1
fi

(set -x; git checkout $master)

if [[ $mode == "squash" ]]; then
    git merge --squash --ff "$@" "$branch"
    git commit --message "Merge branch '$branch'" --edit
elif [[ $mode == "merge" ]]; then
    git merge --no-ff "$@" "$branch"
fi

git branch --move "$branch" "archive/$branch"
